# =============================================================================
# CrafterZ — Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in the values.
# cp .env.example .env.local
#
# NEVER commit .env.local to version control.
# =============================================================================

# ── Core Runtime ──────────────────────────────────────────────────────────────

# PostgreSQL connection string (required for persistence)
# Falls back to in-memory storage if unset
# Formats:
#   Supabase:    postgresql://postgres.<project>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
#   Neon:        postgresql://<user>:<password>@ep-<id>.us-east-2.aws.neon.tech/<db>?sslmode=require
#   Railway:     postgresql://postgres:<password>@<host>:<port>/railway
#   Local:       postgresql://postgres:postgres@localhost:5432/crafterz
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/crafterz

# Neynar API key (required for Farcaster signature verification)
# Get one at https://app.neynar.com/settings/api-keys
# Free tier: 1,000 requests/day
NEYNAR_API_KEY=neynar_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# CoinGecko API key (optional — used for token price lookups)
# Free tier key works; leave blank to use built-in demo key
# Get one at https://www.coingecko.com/en/api/pricing
COINGECKO_API_KEY=CG-XXXXXXXXXXXXXXXXXXXXXXXX

# ── X402 Payment Protocol ────────────────────────────────────────────────────
# See: https://x402.org | Docs: https://docs.x402.org

# Facilitator URL for payment settlement
# Options:
#   Coinbase CDP:  https://api.cdp.coinbase.com/platform/v2/x402
#   x402 testnet:  https://x402.org/facilitator
#   Self-hosted:   https://your-facilitator.example.com/v2/x402
X402_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402

# Receiving wallet addresses for payments
# EVM address (0x format) — Base, Ethereum, Arbitrum, Optimism, Polygon
X402_EVM_ADDRESS=0x0000000000000000000000000000000000000000

# Solana address (base58 format) — optional
X402_SVM_ADDRESS=

# Contract owner address — controls whitelist and admin functions
# Defaults to X402_EVM_ADDRESS if not set
X402_OWNER_ADDRESS=

# Payment prices per action (USD format)
X402_CRAFT_PRICE=$0.01
X402_MINT_PRICE=$0.05
X402_GM_PRICE=$0.50
X402_TASK_PRICE=$0.01

# Whitelisted addresses for free minting (comma-separated, gas only)
# These wallets can mint MegaMinds without X402 payment
# Example: 0xabc...123,0xdef...456
X402_MINT_WHITELIST=

# Legacy contract address (deprecated — kept for backward compatibility)
X402_CONTRACT_ADDRESS=

# Enable testnet mode — skips real payment verification (development only)
# Set to "true" to use the x402.org testnet facilitator
X402_USE_TESTNET=false

# ── AI Crafting Engine ───────────────────────────────────────────────────────
# The AI determines what happens when two items are combined.
# Supports any OpenAI-compatible API. When AI_API_KEY is set, crafting uses
# the AI to generate results dynamically. Without it, falls back to the
# built-in recipe registry (25 hardcoded combinations).

# AI provider API key (required for AI crafting)
# Get one from your chosen provider below
AI_API_KEY=

# AI API base URL (OpenAI-compatible endpoint)
# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ Provider       │ Base URL                                    │ Free Tier?   │
# ├─────────────────────────────────────────────────────────────────────────────┤
# │ OpenAI         │ https://api.openai.com/v1                   │ No (paid)    │
# │ Mistral        │ https://api.mistral.ai/v1                   │ Yes (€2 free)│
# │ Groq           │ https://api.groq.com/openai/v1              │ Yes (limited)│
# │ Together AI    │ https://api.together.xyz/v1                 │ Yes ($25)    │
# │ Anthropic      │ https://api.anthropic.com                   │ Yes ($5)     │
# │ Fireworks AI   │ https://api.fireworks.ai/inference/v1       │ Yes (limited)│
# │ DeepSeek       │ https://api.deepseek.com/v1                 │ Yes (limited)│
# │ Ollama (local) │ http://localhost:11434/v1                   │ Yes (free)   │
# │ LM Studio      │ http://localhost:1234/v1                    │ Yes (free)   │
# └─────────────────────────────────────────────────────────────────────────────┘
AI_API_BASE_URL=https://api.openai.com/v1

# AI model to use for crafting decisions
# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ Provider       │ Model ID                                  │ Speed  │ Cost  │
# ├─────────────────────────────────────────────────────────────────────────────┤
# │ OpenAI         │ gpt-4o-mini                               │ Fast   │ $     │
# │ OpenAI         │ gpt-4o                                    │ Medium │ $$    │
# │ OpenAI         │ o3-mini                                   │ Medium │ $$    │
# │ Mistral        │ mistral-small-latest                      │ Fast   │ $     │
# │ Mistral        │ mistral-large-latest                      │ Medium │ $$    │
# │ Mistral        │ ministral-8b-latest                       │ Fast   │ $     │
# │ Groq           │ llama-3.3-70b-versatile                   │ Fast   │ Free  │
# │ Groq           │ llama-3.1-8b-instant                      │ Fast   │ Free  │
# │ Groq           │ mistral-saba-24b                          │ Fast   │ Free  │
# │ Together       │ meta-llama/Llama-3.3-70B-Instruct-Turbo   │ Fast   │ $     │
# │ Together       │ mistralai/Mixtral-8x7B-Instruct-v0.1      │ Fast   │ $     │
# │ Anthropic      │ claude-sonnet-4-20250514                  │ Medium │ $$    │
# │ Anthropic      │ claude-haiku-3-20241022                   │ Fast   │ $     │
# │ Fireworks      │ accounts/fireworks/models/llama-v3p1-70b  │ Fast   │ $     │
# │ DeepSeek       │ deepseek-chat                             │ Fast   │ $     │
# │ Ollama         │ llama3.2                                  │ Fast   │ Free  │
# │ Ollama         │ mistral                                   │ Fast   │ Free  │
# │ LM Studio      │ (depends on loaded model)                 │ Varies │ Free  │
# └─────────────────────────────────────────────────────────────────────────────┘
# Recommended for production: gpt-4o-mini or mistral-small-latest
# Recommended for free tier: Groq llama-3.3-70b-versatile
AI_MODEL=gpt-4o-mini

# ── Deployment ────────────────────────────────────────────────────────────────

# Vercel production URL — used for Farcaster metadata and public config
# Automatically set by Vercel; override only for custom deployments
# Format: https://your-app.vercel.app
NEXT_PUBLIC_VERCEL_PRODUCTION_URL=
VERCEL_PROJECT_PRODUCTION_URL=
