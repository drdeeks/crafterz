# =============================================================================
# CrafterZ — Git Ignore Rules
# =============================================================================
# Enterprise-optimized .gitignore for Next.js + TypeScript + Drizzle ORM
# =============================================================================

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build Artifacts ──────────────────────────────────────────────────────────
.next/
out/
dist/
build/

# ── Environment ──────────────────────────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# ── Logs & Debug ──────────────────────────────────────────────────────────────
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# ── IDE & Editor ──────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo

# ── Testing ───────────────────────────────────────────────────────────────────
coverage/
.turbo/

# ── Deployment ──────────────────────────────────────────────────────────────
.vercel

# ── Temporary & Backup ────────────────────────────────────────────────────────
*.bak
*.orig
*.tmp

# ── Security ──────────────────────────────────────────────────────────────────
# Never commit secrets or keys
# Use environment variables instead
# =============================================================================
# End of .gitignore
# =============================================================================
