# Core runtime
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/crafterz
NEYNAR_API_KEY=replace-with-your-neynar-api-key
COINGECKO_API_KEY=CG-UviYfmkExfr86X5JFTZfaVbb

# X402 Payment Protocol
# See: https://x402.org

# x402 Facilitator URL (use Coinbase or custom)
X402_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402

# Your wallet addresses for receiving payments
# EVM (Base, Ethereum, etc.) - 0x format
X402_EVM_ADDRESS=0x0000000000000000000000000000000000000000
# Solana - base58 format
X402_SVM_ADDRESS=

# Owner address - can manage whitelist and admin functions
# If not set, defaults to X402_EVM_ADDRESS
X402_OWNER_ADDRESS=

# Payment prices (USD format)
X402_CRAFT_PRICE=$0.01
X402_MINT_PRICE=$0.05
X402_GM_PRICE=$0.50
X402_TASK_PRICE=$0.01

# Whitelisted addresses for free minting (comma-separated, gas only)
# These wallets can mint MegaMinds for free (only pay gas fees)
# Example: X402_MINT_WHITELIST=0xabcd1234...,0xefgh5678...
X402_MINT_WHITELIST=

# Legacy (deprecated - use above instead)
X402_CONTRACT_ADDRESS=
X402_PROTOCOL_VERSION=1.0

# Enable testnet mode (development only)
X402_USE_TESTNET=false

# App URLs
NEXT_PUBLIC_VERCEL_PRODUCTION_URL=
VERCEL_PROJECT_PRODUCTION_URL=

# Optional Next.js/Turbopack overrides
DISABLE_TURBOPACK_ROOT=
TURBOPACK_ROOT=
